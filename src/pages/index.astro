---
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Invoice Builder</title>
    <style>
      :root {
        --app-bg: #eef3f8;
        --panel: #ffffff;
        --ink: #0f172a;
        --muted: #64748b;
        --line: #d6e0eb;
        --line-strong: #b2c1d3;
        --accent: #0a355f;
        --accent-soft: #e6eff8;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        background: var(--app-bg);
        color: var(--ink);
        font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
      }

      .layout {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 360px minmax(0, 1fr);
        gap: 1.2rem;
        padding: 1.2rem;
      }

      .panel {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 14px;
        box-shadow: 0 14px 30px rgba(15, 23, 42, 0.08);
      }

      .controls {
        padding: 1rem;
        position: sticky;
        top: 1rem;
        height: calc(100vh - 2rem);
        overflow: auto;
      }

      .controls h1 {
        margin: 0;
        font-size: 1.4rem;
        font-weight: 700;
      }

      .controls p {
        margin: 0.35rem 0 1rem;
        color: var(--muted);
      }

      fieldset {
        margin: 0 0 0.9rem;
        border: 1px solid var(--line);
        border-radius: 10px;
        padding: 0.7rem;
      }

      legend {
        font-size: 0.8rem;
        color: var(--muted);
        padding: 0 0.35rem;
      }

      label {
        display: block;
        font-size: 0.82rem;
        color: #334155;
        margin: 0.5rem 0 0.2rem;
      }

      input,
      select,
      textarea {
        width: 100%;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        padding: 0.5rem;
        font: inherit;
        font-size: 0.9rem;
        background: #fff;
      }

      textarea {
        min-height: 70px;
        resize: vertical;
      }

      .toolbar {
        display: flex;
        gap: 0.6rem;
        margin-top: 1rem;
      }

      .inline-action {
        display: flex;
        gap: 0.5rem;
        align-items: center;
      }

      .inline-action .btn {
        flex: 0 0 auto;
        white-space: nowrap;
      }

      .line-item-collapsible {
        margin-top: 0.75rem;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        padding: 0.45rem 0.6rem;
        background: #f8fafc;
      }

      .line-item-collapsible[open] {
        padding-bottom: 0.7rem;
      }

      .line-item-collapsible summary {
        cursor: pointer;
        font-size: 0.82rem;
        font-weight: 600;
        color: #334155;
        user-select: none;
      }

      .line-item-collapsible label:first-of-type {
        margin-top: 0.55rem;
      }

      .btn {
        flex: 1;
        border: 0;
        border-radius: 10px;
        padding: 0.65rem 0.8rem;
        font-weight: 600;
        cursor: pointer;
      }

      .btn-primary {
        background: var(--accent);
        color: #fff;
      }

      .btn-secondary {
        background: var(--accent-soft);
        color: #0f172a;
      }

      .workspace {
        min-width: 0;
        display: grid;
        place-items: center;
        padding: 1rem;
      }

      .paper-wrap {
        width: min(100%, 900px);
        padding: 0;
        background: transparent;
        border: 0;
      }

      .paper {
        width: 100%;
        aspect-ratio: 210 / 297;
        background: #fff;
        border: 0;
        border-radius: 0;
        box-shadow:
          0 1px 0 rgba(15, 23, 42, 0.08),
          0 14px 24px rgba(15, 23, 42, 0.14);
        padding: 11.5mm 11mm 10mm;
        display: grid;
        grid-template-rows: auto auto 1fr auto;
        gap: 6mm;
        overflow: hidden;
      }

      .inv-header {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 7mm;
        align-items: start;
        padding-bottom: 4mm;
        border-bottom: 1px solid #b9c8d8;
      }

      .invoice-kicker {
        margin: 0 0 1.4mm;
        font-size: 0.7rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        font-weight: 600;
        color: #0a355f;
      }

      .title {
        margin: 0;
        font-size: 1.85rem;
        letter-spacing: 0.08em;
        color: #0a355f;
      }

      .subtitle {
        margin: 1.6mm 0 0;
        color: #4a6683;
        font-size: 0.78rem;
      }

      .meta-card {
        min-width: 60mm;
        border: 1px solid #b9c8d8;
        border-radius: 8px;
        padding: 3.2mm;
        background: #f7fbff;
      }

      .meta-row {
        display: grid;
        grid-template-columns: auto auto;
        justify-content: space-between;
        gap: 3mm;
        font-size: 0.73rem;
        color: #32495f;
        line-height: 1.45;
      }

      .meta-row strong {
        color: #10243b;
        font-weight: 600;
      }

      .amount-due {
        margin-top: 3mm;
        padding-top: 2.3mm;
        border-top: 1px solid #aabdd1;
      }

      .amount-due span {
        display: block;
        font-size: 0.69rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #4a6683;
      }

      .amount-due strong {
        display: block;
        margin-top: 1mm;
        font-size: 1.05rem;
        color: #0a355f;
      }

      .party-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5mm;
      }

      .card {
        border: 1px solid #c5d4e4;
        border-radius: 8px;
        padding: 4mm;
        background: #fff;
      }

      .card h3 {
        margin: 0;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #365271;
      }

      .card pre {
        margin: 2mm 0 0;
        font-family: inherit;
        white-space: pre-wrap;
        font-size: 0.8rem;
        line-height: 1.45;
      }

      .items-card {
        border: 1px solid #c5d4e4;
        border-radius: 8px;
        overflow: hidden;
      }

      .section-label {
        margin: 0;
        padding: 3mm 3.2mm;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #365271;
        background: #f7fbff;
        border-bottom: 1px solid #c5d4e4;
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      .line-items-table {
        table-layout: fixed;
      }

      .line-items-table th,
      .line-items-table td {
        vertical-align: middle;
      }

      .line-items-table .col-desc {
        width: 52%;
        text-align: left;
      }

      .line-items-table .col-hours {
        width: 14%;
        text-align: center;
      }

      .line-items-table .col-rate,
      .line-items-table .col-total {
        width: 17%;
        text-align: right;
        white-space: nowrap;
        font-variant-numeric: tabular-nums;
      }

      thead th {
        font-size: 0.71rem;
        text-transform: uppercase;
        color: #365271;
        background: #f8fbff;
        padding: 2.4mm 2.2mm;
        border-bottom: 1px solid #c5d4e4;
      }

      tbody td {
        padding: 2.8mm 2.2mm;
        border-bottom: 1px solid #ebf1f7;
        font-size: 0.82rem;
      }

      .total-label {
        text-align: right;
      }

      tfoot td {
        padding: 3.1mm 2.2mm;
        font-size: 0.88rem;
        font-weight: 700;
        border-top: 1.4px solid #7f97b1;
      }

      .footer {
        display: grid;
        grid-template-columns: 1.15fr 1fr;
        gap: 5mm;
      }

      .notes,
      .payment {
        border: 1px solid #c5d4e4;
        border-radius: 8px;
        padding: 3.3mm;
      }

      .notes h4,
      .payment h4 {
        margin: 0 0 2mm;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #0a355f;
      }

      .notes p,
      .payment p {
        margin: 1.2mm 0;
        font-size: 0.78rem;
        line-height: 1.4;
      }

      .notes [data-bind="notesBlock"] {
        white-space: pre-line;
      }

      .payment [data-bind="bankAddress"] {
        white-space: pre-line;
      }

      @media (max-width: 1080px) {
        .layout {
          grid-template-columns: 1fr;
        }

        .controls {
          position: static;
          height: auto;
        }
      }

      @media screen and (max-width: 760px) {
        .paper {
          aspect-ratio: auto;
          min-height: 297mm;
        }

        .inv-header,
        .party-grid,
        .footer {
          grid-template-columns: 1fr;
        }

        .meta-card {
          width: 100%;
          min-width: 0;
        }
      }

      @media print {
        @page {
          size: A4;
          margin: 8mm;
        }

        html,
        body {
          background: #fff;
          print-color-adjust: exact;
          -webkit-print-color-adjust: exact;
        }

        .layout {
          display: block;
          padding: 0;
        }

        .controls {
          display: none;
        }

        .workspace {
          padding: 0;
        }

        .paper-wrap {
          width: auto;
          max-width: none;
          margin: 0;
          padding: 0;
          border: 0;
          background: transparent;
        }

        .paper {
          width: 100%;
          height: auto;
          min-height: calc(297mm - 16mm);
          aspect-ratio: 210 / 297;
          border: 0;
          border-radius: 0;
          box-shadow: none;
          page-break-inside: avoid;
          break-inside: avoid;
          padding: 6mm 7mm 5mm;
          gap: 5mm;
          overflow: visible;
        }

        .inv-header {
          grid-template-columns: 1fr auto;
          padding-bottom: 2mm;
          border-bottom: 0;
        }

        .party-grid {
          grid-template-columns: 1fr 1fr;
          gap: 4mm;
        }

        .footer {
          grid-template-columns: 1.15fr 1fr;
          gap: 4mm;
        }

        .meta-card {
          min-width: 60mm;
          width: auto;
          padding: 2.8mm;
        }

        .card,
        .notes,
        .payment {
          padding: 2.6mm;
        }

        .items-card {
          padding: 0;
          background: #fff;
        }

        .section-label {
          padding: 2mm 2.2mm;
          background: #fff;
          border-bottom: 1px solid #c5d4e4;
        }

        thead th,
        tbody td,
        tfoot td {
          border: 0;
        }

        thead th {
          padding: 2mm 1.8mm;
          background: #fff;
          border-bottom: 1px solid #c5d4e4;
        }

        tbody td {
          padding: 2mm 1.8mm;
          border-bottom: 1px solid #d9e3ee;
        }

        tfoot td {
          padding: 2.2mm 1.8mm 0;
          border-top: 1.2px solid #7f97b1;
        }

        .notes p,
        .payment p {
          margin: 1mm 0;
        }
      }
    </style>
  </head>
  <body>
    <main class="layout">
      <aside class="panel controls">
        <h1>Invoice Data</h1>
        <p style="margin:0.7rem 0 1rem;padding:0.8rem 0.95rem;border:1px solid #cbd5e1;border-radius:8px;background:#f8fafc;font-size:0.84rem;line-height:1.45;color:#334155;">
          Fill in the form below to build your invoice. The preview updates live, and you can use browser autofill or load your saved sender/payment profile before downloading your PDF.
        </p>

        <fieldset>
          <legend>Header</legend>
          <label for="invoiceNumber">Invoice number</label>
          <input id="invoiceNumber" />
          <label for="issuedDate">Date issued</label>
          <input id="issuedDate" />
          <label for="currency">Currency</label>
          <select id="currency">
            <option value="USD" selected>USD</option>
            <option value="EUR">EUR</option>
          </select>
        </fieldset>

        <fieldset>
          <legend>Parties</legend>
          <label for="fromName">From name</label>
          <input id="fromName" placeholder="Your name" autocomplete="name" />
          <label for="fromAddress">From address</label>
          <textarea id="fromAddress" placeholder="Your address" autocomplete="street-address"></textarea>

          <label for="toName">Client name</label>
          <input id="toName" placeholder="Client name" autocomplete="organization" />
          <label for="toAddress">Client address</label>
          <textarea id="toAddress" placeholder="Client address" autocomplete="street-address"></textarea>
        </fieldset>

        <fieldset>
          <legend>Billing</legend>
          <p style="margin:0 0 0.45rem;font-size:0.8rem;color:#475569;">Line item 1</p>
          <label for="workDescription">Description</label>
          <input id="workDescription" placeholder="Describe the work delivered" />
          <label for="hours">Hours</label>
          <input id="hours" type="number" step="0.1" min="0" placeholder="0.0" />
          <label id="rateLabel1" for="rate">Rate per hour (USD)</label>
          <input id="rate" type="number" step="0.01" min="0" value="0.00" />

          <details class="line-item-collapsible">
            <summary>Line item 2 (optional)</summary>
            <label for="workDescription2">Description</label>
            <input id="workDescription2" placeholder="Optional line item description" />
            <label for="hours2">Hours</label>
            <input id="hours2" type="number" step="0.1" min="0" placeholder="0.0" />
            <label id="rateLabel2" for="rate2">Rate per hour (USD)</label>
            <input id="rate2" type="number" step="0.01" min="0" placeholder="0.00" />
          </details>

          <details class="line-item-collapsible">
            <summary>Line item 3 (optional)</summary>
            <label for="workDescription3">Description</label>
            <input id="workDescription3" placeholder="Optional line item description" />
            <label for="hours3">Hours</label>
            <input id="hours3" type="number" step="0.1" min="0" placeholder="0.0" />
            <label id="rateLabel3" for="rate3">Rate per hour (USD)</label>
            <input id="rate3" type="number" step="0.01" min="0" placeholder="0.00" />
          </details>
        </fieldset>

        <fieldset>
          <legend>Notes</legend>
          <details class="line-item-collapsible">
            <summary>Edit notes (optional)</summary>
            <label for="notes">Notes text</label>
            <textarea id="notes" rows="4" placeholder="Add invoice notes"></textarea>
            <p style="margin:0.5rem 0 0;font-size:0.78rem;color:#64748b;">
              Tip: Use <code>&#123;&#123;invoiceNumber&#125;&#125;</code> to insert the current invoice number.
            </p>
          </details>
        </fieldset>

        <fieldset>
          <legend>Payment details</legend>
          <label for="bankName">Bank</label>
          <input id="bankName" placeholder="Bank name" />
          <label for="bankAddress">Bank address</label>
          <textarea id="bankAddress" placeholder="Bank address"></textarea>
          <label for="accountName">Account holder</label>
          <input id="accountName" placeholder="Account holder name" autocomplete="name" />
          <label for="iban">IBAN</label>
          <input id="iban" placeholder="Enter IBAN" />
          <label for="bic">BIC / SWIFT</label>
          <input id="bic" placeholder="Enter BIC / SWIFT" />
          <label for="correspondentBic">Correspondent BIC (USD)</label>
          <input id="correspondentBic" placeholder="Enter correspondent BIC for USD transfers" />
        </fieldset>

        <fieldset>
          <legend>Browser profile</legend>
          <p style="margin:0 0 0.55rem;font-size:0.8rem;line-height:1.45;color:#475569;">
            Saves your sender and payment details (currency, from name/address, and bank fields) in this browser only.
            It stays on this device and does not sync to other browsers or devices.
          </p>
          <div class="inline-action">
            <button id="loadLocalProfile" class="btn btn-secondary" type="button">Load Saved</button>
            <button id="saveLocalProfile" class="btn btn-primary" type="button">Save to Browser</button>
          </div>
          <p id="profileStatus" style="margin:0.6rem 0 0;font-size:0.8rem;color:#475569;"></p>
        </fieldset>

        <div class="toolbar">
          <button id="downloadPdf" class="btn btn-primary" type="button">Download PDF</button>
          <button id="resetDemo" class="btn btn-secondary" type="button">Reset Form</button>
        </div>
      </aside>

      <section class="workspace">
        <div class="paper-wrap">
          <article id="invoicePaper" class="paper">
            <header class="inv-header">
              <div>
                <p class="invoice-kicker">Professional Services</p>
                <h2 class="title">Invoice</h2>
                <p class="subtitle">Please remit payment by bank transfer using invoice reference.</p>
              </div>
              <div class="meta-card">
                <div class="meta-row"><span>Invoice no.</span> <strong data-bind="invoiceNumber"></strong></div>
                <div class="meta-row"><span>Date issued</span> <strong data-bind="issuedDate"></strong></div>
                <div class="meta-row"><span>Currency</span> <strong data-bind="currency"></strong></div>
                <div class="amount-due">
                  <span>Total due</span>
                  <strong data-bind="grandTotal"></strong>
                </div>
              </div>
            </header>

            <section class="party-grid">
              <div class="card">
                <h3>From</h3>
                <pre data-bind="fromBlock"></pre>
              </div>
              <div class="card">
                <h3>Bill To</h3>
                <pre data-bind="toBlock"></pre>
              </div>
            </section>

            <section class="items-card">
              <p class="section-label">Line items</p>
              <table class="line-items-table">
                <thead>
                  <tr>
                    <th class="col-desc">Description</th>
                    <th class="col-hours">Hours</th>
                    <th class="col-rate">Rate</th>
                    <th class="col-total">Line total</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td class="col-desc" data-bind="line1Description"></td>
                    <td class="col-hours" data-bind="line1Hours"></td>
                    <td class="col-rate" data-bind="line1RateFormatted"></td>
                    <td class="col-total" data-bind="line1Total"></td>
                  </tr>
                  <tr id="lineItemRow2" style="display:none;">
                    <td class="col-desc" data-bind="line2Description"></td>
                    <td class="col-hours" data-bind="line2Hours"></td>
                    <td class="col-rate" data-bind="line2RateFormatted"></td>
                    <td class="col-total" data-bind="line2Total"></td>
                  </tr>
                  <tr id="lineItemRow3" style="display:none;">
                    <td class="col-desc" data-bind="line3Description"></td>
                    <td class="col-hours" data-bind="line3Hours"></td>
                    <td class="col-rate" data-bind="line3RateFormatted"></td>
                    <td class="col-total" data-bind="line3Total"></td>
                  </tr>
                </tbody>
                <tfoot>
                  <tr>
                    <td colspan="3" class="total-label">Total amount due</td>
                    <td class="col-total" data-bind="grandTotal"></td>
                  </tr>
                </tfoot>
              </table>
            </section>

            <footer class="footer">
              <div class="notes">
                <h4>Notes</h4>
                <p data-bind="notesBlock"></p>
              </div>
              <div class="payment">
                <h4>Payment routing</h4>
                <p><strong>Bank:</strong> <span data-bind="bankName"></span></p>
                <p><strong>Bank address:</strong> <span data-bind="bankAddress"></span></p>
                <p><strong>Account:</strong> <span data-bind="accountName"></span></p>
                <p><strong>IBAN:</strong> <span data-bind="iban"></span></p>
                <p><strong>BIC:</strong> <span data-bind="bic"></span></p>
                <p><strong>Correspondent BIC:</strong> <span data-bind="correspondentBic"></span></p>
              </div>
            </footer>
          </article>
        </div>
      </section>
    </main>

    <script>
      /**
       * @typedef {HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement} FormField
       */

      const todayIssuedDate = new Intl.DateTimeFormat("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric"
      }).format(new Date());

      /**
       * @param {number} year
       * @param {number} sequence
       */
      const formatInvoiceCode = (year, sequence) => `INV-${year}-${String(sequence).padStart(3, "0")}`;

      /**
       * @param {string} key
       */
      const getStoredSequence = (key) => {
        const value = Number.parseInt(localStorage.getItem(key) || "", 10);
        return Number.isFinite(value) && value > 0 ? value : null;
      };

      const getCurrentInvoiceCode = () => {
        const year = new Date().getFullYear();
        const key = `invoice-sequence-${year}`;

        try {
          const current = getStoredSequence(key) ?? 1;
          return formatInvoiceCode(year, current);
        } catch {
          return `INV-${year}-001`;
        }
      };

      const advanceInvoiceCode = () => {
        const year = new Date().getFullYear();
        const key = `invoice-sequence-${year}`;

        try {
          const current = getStoredSequence(key) ?? 1;
          const next = current + 1;
          localStorage.setItem(key, String(next));
          return formatInvoiceCode(year, next);
        } catch {
          return `INV-${year}-001`;
        }
      };

      const defaultNotesTemplate =
        "Please include {{invoiceNumber}} in your transfer reference.\nPayment is due within 14 days unless otherwise agreed.";

      const initialData = {
        invoiceNumber: getCurrentInvoiceCode(),
        issuedDate: todayIssuedDate,
        currency: "USD",
        fromName: "",
        fromAddress: "",
        toName: "",
        toAddress: "",
        workDescription: "",
        hours: "",
        rate: "0.00",
        workDescription2: "",
        hours2: "",
        rate2: "",
        workDescription3: "",
        hours3: "",
        rate3: "",
        bankName: "",
        bankAddress: "",
        accountName: "",
        iban: "",
        bic: "",
        correspondentBic: "",
        notes: defaultNotesTemplate
      };

      /** @typedef {typeof initialData} InvoiceData */

      /**
       * @param {string} id
       * @returns {HTMLElement}
       */
      const getRequiredElement = (id) => {
        const element = document.getElementById(id);

        if (!element) {
          throw new Error(`Missing element: ${id}`);
        }

        return element;
      };

      /**
       * @param {string} id
       * @returns {FormField}
       */
      const getFormField = (id) => {
        const element = getRequiredElement(id);

        if (
          element instanceof HTMLInputElement ||
          element instanceof HTMLTextAreaElement ||
          element instanceof HTMLSelectElement
        ) {
          return element;
        }

        throw new Error(`Expected form field: ${id}`);
      };

      /**
       * @param {string} id
       * @returns {HTMLLabelElement}
       */
      const getLabelElement = (id) => {
        const element = getRequiredElement(id);

        if (element instanceof HTMLLabelElement) {
          return element;
        }

        throw new Error(`Expected label element: ${id}`);
      };

      /**
       * @param {string} id
       * @returns {HTMLTableRowElement}
       */
      const getTableRow = (id) => {
        const element = getRequiredElement(id);

        if (element instanceof HTMLTableRowElement) {
          return element;
        }

        throw new Error(`Expected table row: ${id}`);
      };

      /**
       * @param {string} id
       * @returns {HTMLButtonElement}
       */
      const getButtonElement = (id) => {
        const element = getRequiredElement(id);

        if (element instanceof HTMLButtonElement) {
          return element;
        }

        throw new Error(`Expected button element: ${id}`);
      };

      /** @type {(keyof InvoiceData)[]} */
      const ids = /** @type {(keyof InvoiceData)[]} */ (Object.keys(initialData));
      /** @type {Record<keyof InvoiceData, FormField>} */
      const inputs = /** @type {Record<keyof InvoiceData, FormField>} */ (
        Object.fromEntries(ids.map((id) => [id, getFormField(id)]))
      );
      const rateLabels = [
        getLabelElement("rateLabel1"),
        getLabelElement("rateLabel2"),
        getLabelElement("rateLabel3")
      ];
      const lineItemRow2 = getTableRow("lineItemRow2");
      const lineItemRow3 = getTableRow("lineItemRow3");
      const PROFILE_STORAGE_KEY = "invoice-profile-v1";
      /** @type {(keyof InvoiceData)[]} */
      const PROFILE_FIELDS = [
        "currency",
        "fromName",
        "fromAddress",
        "bankName",
        "bankAddress",
        "accountName",
        "iban",
        "bic",
        "correspondentBic"
      ];

      /**
       * @param {number} amount
       * @param {string} currencyCode
       */
      const formatCurrency = (amount, currencyCode) =>
        new Intl.NumberFormat("en-US", {
          style: "currency",
          currency: currencyCode || "USD"
        }).format(amount);

      /**
       * @param {string} value
       */
      const sanitizeFilenamePart = (value) =>
        (value || "")
          .toString()
          .trim()
          .replace(/[^a-z0-9]+/gi, "-")
          .replace(/^-+|-+$/g, "");

      /**
       * @param {InvoiceData} data
       */
      const buildPrintTitle = (data) => {
        const invoicePart = sanitizeFilenamePart(data.invoiceNumber) || "invoice";
        const clientPart = sanitizeFilenamePart(data.toName);
        return ["invoice", invoicePart, clientPart].filter(Boolean).join("_");
      };

      /**
       * @param {keyof InvoiceData} key
       * @param {string} value
       */
      const assignIfPresent = (key, value) => {
        if (inputs[key] && typeof value === "string") {
          inputs[key].value = value;
        }
      };

      /**
       * @param {Partial<InvoiceData>} profileData
       */
      const applyProfileValues = (profileData) => {
        for (const key of PROFILE_FIELDS) {
          assignIfPresent(key, profileData?.[key] ?? "");
        }
      };

      /**
       * @returns {InvoiceData}
       */
      const getData = () => {
        const values = { ...initialData };
        for (const id of ids) values[id] = inputs[id].value.trim();
        return values;
      };

      const applyInitialData = () => {
        for (const id of ids) {
          inputs[id].value = initialData[id];
        }
      };

      /**
       * @param {string} key
       * @param {string} value
       */
      const setText = (key, value) => {
        document.querySelectorAll(`[data-bind="${key}"]`).forEach((node) => {
          node.textContent = value;
        });
      };

      /**
       * @param {string} value
       */
      const toNonNegativeNumber = (value) => Math.max(0, Number.parseFloat(value) || 0);

      const render = () => {
        const data = getData();
        const currencyCode = data.currency || "USD";
        const effectiveAccountName = data.accountName || data.fromName;
        const notesTemplate = data.notes || defaultNotesTemplate;
        const resolvedNotes = notesTemplate.replaceAll("{{invoiceNumber}}", data.invoiceNumber || "-");
        const lineItems = [
          {
            description: data.workDescription,
            hoursRaw: data.hours,
            rateRaw: data.rate,
            row: null,
            descriptionKey: "line1Description",
            hoursKey: "line1Hours",
            rateKey: "line1RateFormatted",
            totalKey: "line1Total",
            fallbackDescription: "Work item"
          },
          {
            description: data.workDescription2,
            hoursRaw: data.hours2,
            rateRaw: data.rate2,
            row: lineItemRow2,
            descriptionKey: "line2Description",
            hoursKey: "line2Hours",
            rateKey: "line2RateFormatted",
            totalKey: "line2Total",
            fallbackDescription: "Additional item"
          },
          {
            description: data.workDescription3,
            hoursRaw: data.hours3,
            rateRaw: data.rate3,
            row: lineItemRow3,
            descriptionKey: "line3Description",
            hoursKey: "line3Hours",
            rateKey: "line3RateFormatted",
            totalKey: "line3Total",
            fallbackDescription: "Additional item"
          }
        ];
        let grandTotal = 0;

        lineItems.forEach((item, index) => {
          const hours = toNonNegativeNumber(item.hoursRaw);
          const rate = toNonNegativeNumber(item.rateRaw);
          const lineTotal = hours * rate;
          const hasContent = Boolean(
            (item.description || "").trim() ||
              (item.hoursRaw || "").trim() ||
              (item.rateRaw || "").trim()
          );
          const visible = index === 0 || hasContent;

          if (item.row) {
            item.row.style.display = visible ? "" : "none";
          }

          if (visible) {
            setText(item.descriptionKey, item.description || item.fallbackDescription);
            setText(item.hoursKey, hours.toFixed(2));
            setText(item.rateKey, formatCurrency(rate, currencyCode));
            setText(item.totalKey, formatCurrency(lineTotal, currencyCode));
            grandTotal += lineTotal;
          } else {
            setText(item.descriptionKey, "");
            setText(item.hoursKey, "");
            setText(item.rateKey, "");
            setText(item.totalKey, "");
          }
        });

        setText("invoiceNumber", data.invoiceNumber || "-");
        setText("issuedDate", data.issuedDate || "-");
        setText("currency", currencyCode);
        setText("grandTotal", formatCurrency(grandTotal, currencyCode));
        rateLabels.forEach((label) => {
          if (label) label.textContent = `Rate per hour (${currencyCode})`;
        });
        setText("fromBlock", `${data.fromName || "-"}\n${data.fromAddress || "-"}`);
        setText("toBlock", `${data.toName || "-"}\n${data.toAddress || "-"}`);
        setText("bankName", data.bankName || "-");
        setText("bankAddress", data.bankAddress || "-");
        setText("accountName", effectiveAccountName || "-");
        setText("iban", data.iban || "Pending");
        setText("bic", data.bic || "Pending");
        setText("correspondentBic", data.currency === "USD" ? data.correspondentBic || "If required by sender bank" : "N/A");
        setText("notesBlock", resolvedNotes);

      };

      ids.forEach((id) => inputs[id].addEventListener("input", render));

      getButtonElement("downloadPdf").addEventListener("click", () => {
        const previousTitle = document.title;
        document.title = buildPrintTitle(getData());

        const restoreTitle = () => {
          document.title = previousTitle;
        };

        window.addEventListener("afterprint", restoreTitle, { once: true });
        window.print();
        setTimeout(restoreTitle, 0);
      });

      getButtonElement("resetDemo").addEventListener("click", () => {
        applyInitialData();
        inputs.invoiceNumber.value = advanceInvoiceCode();
        render();
      });

      getButtonElement("saveLocalProfile").addEventListener("click", () => {
        const profileStatus = getRequiredElement("profileStatus");
        profileStatus.textContent = "Saving to browser...";

        const data = getData();
        const profilePayload = {
          currency: data.currency || "USD",
          fromName: data.fromName,
          fromAddress: data.fromAddress,
          bankName: data.bankName,
          bankAddress: data.bankAddress,
          accountName: data.accountName || data.fromName,
          iban: data.iban,
          bic: data.bic,
          correspondentBic: data.correspondentBic
        };

        try {
          localStorage.setItem(PROFILE_STORAGE_KEY, JSON.stringify(profilePayload));
          profileStatus.textContent = "Saved to browser.";
        } catch (error) {
          profileStatus.textContent = `Save failed: ${error instanceof Error ? error.message : "Unknown error"}`;
        }
      });

      getButtonElement("loadLocalProfile").addEventListener("click", () => {
        const profileStatus = getRequiredElement("profileStatus");
        profileStatus.textContent = "Loading saved values from browser...";

        try {
          const raw = localStorage.getItem(PROFILE_STORAGE_KEY);
          if (!raw) {
            profileStatus.textContent = "No saved values in this browser yet.";
            return;
          }

          const data = /** @type {Partial<InvoiceData>} */ (JSON.parse(raw));
          applyProfileValues(data);
          render();

          const loadedCurrency = typeof data.currency === "string" && data.currency ? data.currency : "USD";
          profileStatus.textContent = `Loaded ${loadedCurrency} values from browser storage.`;
        } catch (error) {
          profileStatus.textContent = `Load failed: ${error instanceof Error ? error.message : "Unknown error"}`;
        }
      });

      applyInitialData();
      render();
    </script>
  </body>
</html>
